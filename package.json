{
    "private": true,
    "name": "strudel-webxdc",
    "version": "1.0.0",
    "description": "Plain webxdc template",
    "license": "MIT",
    "keywords": [
        "webxdc"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/Amzd/music-webxdc.git"
    },
    "bugs": {
        "url": "https://github.com/Amzd/music-webxdc/issues"
    },
    "homepage": "https://github.com/Amzd/music-webxdc",
    "type": "module",
    "packageManager": "pnpm@10.14.0",
    "scripts": {
        "build": "vite build",
        "check:eslint": "eslint --cache .",
        "check:format": "prettier --check --cache .",
        "check:types": "tsc",
        "check": "pnpm run \"/^check:.*/\"",
        "prepare": "husky",
        "emulator": "concurrently \"vite dev\" \"webxdc-dev run http://localhost:5173 --port 2468\""
    },
    "devDependencies": {
        "@eslint/compat": "1.3.1",
        "@eslint/js": "9.32.0",
        "@ianvs/prettier-plugin-sort-imports": "4.5.1",
        "@resvg/resvg-js": "^2.6.2",
        "@types/node": "22.16.5",
        "@webxdc/types": "2.1.2",
        "@webxdc/vite-plugins": "1.5.1",
        "@webxdc/webxdc-dev": "0.19.0",
        "concurrently": "^9.2.1",
        "eslint": "9.32.0",
        "globals": "16.3.0",
        "husky": "9.1.7",
        "nano-staged": "0.8.0",
        "prettier": "3.6.2",
        "prettier-plugin-jsdoc": "1.3.3",
        "typescript": "5.8.3",
        "typescript-eslint": "8.38.0",
        "vite": "7.0.6"
    },
    "pnpm": {
        "ignoredBuiltDependencies": [
            "core-js"
        ],
        "onlyBuiltDependencies": [
            "esbuild"
        ],
        "overrides": {
            "@vitejs/plugin-basic-ssl": "2.0.0"
        }
    },
    "dependencies": {
        "@strudel/codemirror": "^1.3.0",
        "@strudel/core": "^1.2.6",
        "@strudel/draw": "^1.2.6",
        "@strudel/repl": "^1.3.0",
        "@strudel/soundfonts": "^1.3.0",
        "@strudel/transpiler": "^1.2.6",
        "@strudel/webaudio": "^1.3.0"
    }
}
